{
  "name": "opendb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.1.x",
  "scripts": {
    "dev": "./bin/bunx vite",
    "dev:mock": "VITE_MOCK_MODE=true ./bin/bunx vite",
    "build": "./bin/bunx tsc && ./bin/bunx vite build",
    "preview": "./bin/bunx vite preview",
    "tauri": "./bin/bunx tauri",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"src-tauri/src/**/*.rs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"src-tauri/src/**/*.rs\"",
    "rust:check": "cd src-tauri && cargo check",
    "rust:fmt": "cd src-tauri && cargo fmt --all",
    "rust:test": "cd src-tauri && cargo test",
    "test:unit": "./bin/bun test --run",
    "test:watch": "./bin/bun test --watch",
    "test:smoke": "./bin/bun run typecheck && ./bin/bun run rust:check",
    "test:all": "./bin/bun run typecheck && ./bin/bun run format:check && ./bin/bun run rust:check && ./bin/bun run rust:test && ./bin/bun run test:unit",
    "test:ci": "./bin/bun run test:all"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@types/papaparse": "^5.5.2",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^2.1.9",
    "sql-formatter": "^15.7.3",
    "tauri-plugin-secure-storage": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/bun": "^1.1.13",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
