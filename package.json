{
  "name": "crabhub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "dev:mock": "VITE_MOCK_MODE=true npx vite",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "tauri": "npx tauri",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"src-tauri/src/**/*.rs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"src-tauri/src/**/*.rs\"",
    "rust:check": "cd src-tauri && cargo check",
    "rust:fmt": "cd src-tauri && cargo fmt --all",
    "rust:test": "cd src-tauri && cargo test",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "npm run typecheck && npm run rust:check",
    "test:all": "npm run typecheck && npm run format:check && npm run rust:check && npm run rust:test && npm run test:unit",
    "test:ci": "npm run test:all"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@types/papaparse": "^5.5.2",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sql-formatter": "^15.7.3",
    "tauri-plugin-secure-storage": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.7",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.6"
  }
}
